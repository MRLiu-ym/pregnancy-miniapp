.page{background:#f8f8f8;min-height:100vh;padding:24rpx 24rpx 120rpx}.card{background:#fff;border-radius:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin-bottom:24rpx;padding:28rpx}.card-title{margin-bottom:24rpx}.card-title text{color:#333;font-size:30rpx;font-weight:700}.no-data{color:#ccc;display:block;font-size:26rpx;padding:40rpx 0;text-align:center}.chart-simple{align-items:flex-end;display:flex;gap:16rpx;height:200rpx;justify-content:center;padding-top:20rpx}.bar-wrap{align-items:center;display:flex;flex:1;flex-direction:column;gap:6rpx;max-width:60rpx}.bar{background:linear-gradient(0deg,#f472b6,#f9a8d4);border-radius:8rpx 8rpx 0 0;min-height:20rpx;transition:height .3s ease;width:100%}.bar-date{color:#ccc;font-size:18rpx}.bar-val{color:#666;font-size:20rpx;font-weight:600}.list-row{align-items:center;border-bottom:1rpx solid #f8f8f8;display:flex;justify-content:space-between;padding:18rpx 0}.list-row:last-child{border-bottom:none}.list-date{color:#999;font-size:24rpx}.list-val{font-size:28rpx;font-weight:700}.list-val.high{color:#dc2626}.list-val.ok{color:#22c55e}.stats{display:flex;gap:16rpx}.stat-card{background:#fff;border-radius:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);flex:1;padding:24rpx;text-align:center}.stat-label{color:#999;display:block;font-size:22rpx}.stat-num{color:#333;display:block;font-size:40rpx;font-weight:700;margin-top:8rpx}