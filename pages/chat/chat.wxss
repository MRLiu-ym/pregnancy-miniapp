.chat-page{display:flex;flex-direction:column;height:100vh}.msg-list{flex:1;padding:24rpx 24rpx 16rpx}.msg{display:flex;margin-bottom:24rpx}.msg.user{justify-content:flex-end}.bubble{border-radius:24rpx;max-width:80%;padding:20rpx 24rpx}.bubble.user{background:#f472b6;border-bottom-right-radius:8rpx}.bubble.user .bubble-text{color:#fff}.bubble.assistant{background:#f5f5f5;border-bottom-left-radius:8rpx}.bubble-text{font-size:28rpx;line-height:1.6;white-space:pre-wrap}.input-bar{background:#fff;border-top:1rpx solid #f0f0f0;display:flex;gap:12rpx;padding:16rpx 24rpx}.chat-input{background:#f5f5f5;border-radius:24rpx;flex:1;font-size:28rpx;padding:16rpx 24rpx}.send-btn{background:#f472b6;border-radius:24rpx;color:#fff;font-size:28rpx;padding:16rpx 28rpx}.quick-btns{display:flex;flex-wrap:wrap;gap:10rpx;padding:0 24rpx 16rpx}.quick{background:#f5f5f5;border-radius:20rpx;color:#666;font-size:24rpx;padding:10rpx 20rpx}