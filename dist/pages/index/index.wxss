.welcome{align-items:center;background:linear-gradient(180deg,#fff5f7,#fff);display:flex;flex-direction:column;justify-content:center;min-height:100vh;padding:60rpx;text-align:center}.welcome-emoji{animation:float 3s ease-in-out infinite;font-size:80rpx;margin-bottom:30rpx}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10rpx)}}.welcome-title{color:#333;font-size:40rpx;font-weight:700;margin-bottom:16rpx}.welcome-desc{color:#999;font-size:28rpx;line-height:1.6;margin-bottom:40rpx;white-space:pre-line}.btn{background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:40rpx;box-shadow:0 4rpx 20rpx rgba(244,114,182,.3);color:#fff;font-size:32rpx;font-weight:700;padding:24rpx 60rpx}.page{background:#f8f8f8;min-height:100vh;padding:24rpx 24rpx 120rpx}.card-gradient{background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:32rpx;box-shadow:0 4rpx 20rpx rgba(244,114,182,.25);margin-bottom:24rpx;padding:36rpx}.progress-wrap{align-items:center;display:flex;gap:30rpx}.progress-circle{align-items:center;background:hsla(0,0%,100%,.2);border:4rpx solid hsla(0,0%,100%,.3);border-radius:50%;display:flex;flex-direction:column;flex-shrink:0;height:140rpx;justify-content:center;width:140rpx}.progress-num{color:#fff;font-size:56rpx;font-weight:700}.progress-total{color:hsla(0,0%,100%,.7);font-size:22rpx}.progress-info{flex:1}.stage{color:hsla(0,0%,100%,.8);font-size:24rpx}.week{color:#fff;font-size:36rpx;font-weight:700;margin:6rpx 0}.due{color:hsla(0,0%,100%,.7);font-size:24rpx}.countdown{background:hsla(0,0%,100%,.2);border-radius:20rpx;display:inline-block;margin-top:12rpx;padding:10rpx 18rpx}.countdown text{color:#fff;font-size:22rpx;font-weight:500}.risk-card{border-radius:24rpx;display:flex;gap:16rpx;margin-bottom:16rpx;padding:24rpx}.risk-urgent{background:#fef2f2;border:1rpx solid #fecaca}.risk-high{background:#fffbeb;border:1rpx solid #fde68a}.risk-attention{background:#f0f9ff;border:1rpx solid #bae6fd}.risk-icon{flex-shrink:0;font-size:32rpx}.risk-body{flex:1}.risk-title{color:#333;display:block;font-size:28rpx;font-weight:700}.risk-desc{color:#666;display:block;font-size:24rpx;line-height:1.5;margin-top:6rpx}.risk-sugg{color:#333;display:block;font-size:24rpx;font-weight:500;margin-top:8rpx}.card{background:#fff;border-radius:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin-bottom:24rpx;padding:28rpx}.card-header{align-items:center;display:flex;gap:16rpx;margin-bottom:16rpx}.baby-emoji{animation:heartbeat 1.5s ease-in-out infinite;font-size:44rpx}@keyframes heartbeat{0%,100%{transform:scale(1)}15%{transform:scale(1.15)}30%{transform:scale(1)}45%{transform:scale(1.1)}60%{transform:scale(1)}}.card-title{color:#333;display:block;font-size:30rpx;font-weight:700}.card-sub{color:#999;display:block;font-size:22rpx;margin-top:4rpx}.fetal-desc{color:#666;display:block;font-size:26rpx;line-height:1.5;margin-bottom:16rpx}.milestones{display:flex;flex-wrap:wrap;gap:10rpx}.tag{background:#fce4ec;border-radius:20rpx;color:#db2777;font-size:22rpx;font-weight:500;padding:8rpx 18rpx}.grid-3{display:grid;gap:16rpx;grid-template-columns:1fr 1fr 1fr;margin-bottom:24rpx}.quick-btn{align-items:center;background:#fff;border-radius:20rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);display:flex;flex-direction:column;gap:8rpx;padding:24rpx 16rpx;transition:transform .2s}.quick-btn:active{transform:scale(.95)}.quick-icon{font-size:36rpx}.quick-label{color:#666;font-size:22rpx;font-weight:500}.reminder-card{background:#fff;border-radius:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);margin-bottom:16rpx;padding:24rpx}.reminder-top{align-items:center;display:flex;justify-content:space-between;margin-bottom:12rpx}.reminder-type{color:#999;font-size:22rpx}.reminder-pri{border-radius:10rpx;font-size:20rpx;font-weight:500;padding:4rpx 12rpx}.reminder-pri.urgent{background:#fee2e2;color:#dc2626}.reminder-pri.high{background:#fef3c7;color:#d97706}.reminder-pri.normal{background:#dbeafe;color:#2563eb}.reminder-title{color:#333;display:block;font-size:30rpx;font-weight:700;margin-bottom:8rpx}.reminder-desc{color:#666;display:block;font-size:24rpx;line-height:1.5}.reminder-time{color:#999;display:block;font-size:22rpx;margin-top:10rpx}.reminder-item{align-items:center;border-bottom:1rpx solid #f5f5f5;display:flex;gap:12rpx;padding:16rpx 0}.reminder-item:last-child{border-bottom:none}.reminder-item text{color:#333;font-size:26rpx}.husband-card{background:linear-gradient(135deg,#eff6ff,#dbeafe);border:1rpx solid #bfdbfe}