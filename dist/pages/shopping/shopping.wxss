.page{background:#f8f8f8;display:flex;flex-direction:column;height:100vh}.progress-bar-wrap{background:#fff;border-bottom:1rpx solid #f0f0f0;padding:24rpx}.progress-top{display:flex;justify-content:space-between;margin-bottom:10rpx}.progress-label{color:#333;font-size:26rpx;font-weight:600}.progress-num{color:#f472b6;font-size:24rpx;font-weight:600}.progress-bar{background:#f0f0f0;border-radius:5rpx;height:10rpx;overflow:hidden}.progress-fill{background:linear-gradient(90deg,#f472b6,#ec4899);border-radius:5rpx;height:100%;transition:width .3s}.scroll{flex:1;padding:16rpx}.stage-card{background:#fff;border-radius:20rpx;margin-bottom:16rpx;overflow:hidden}.stage-header{align-items:center;display:flex;justify-content:space-between;padding:24rpx}.stage-left{align-items:center;display:flex;gap:14rpx}.stage-icon{font-size:32rpx}.stage-name{color:#333;display:block;font-size:28rpx;font-weight:600}.stage-count{color:#999;display:block;font-size:22rpx;margin-top:2rpx}.stage-arrow{color:#999;font-size:28rpx}.stage-items{border-top:1rpx solid #f5f5f5}.shop-item{align-items:center;border-bottom:1rpx solid #f9f9f9;display:flex;gap:14rpx;padding:18rpx 24rpx}.shop-item:last-child{border-bottom:none}.shop-item.checked{background:#f9fafb}.checkbox{align-items:center;border:2rpx solid #ddd;border-radius:10rpx;display:flex;flex-shrink:0;height:40rpx;justify-content:center;width:40rpx}.checkbox.checked{background:#f472b6;border-color:#f472b6}.check-mark{color:#fff;font-size:22rpx;font-weight:700}.item-info{flex:1}.item-name{color:#333;display:block;font-size:26rpx}.item-name.done{color:#999;text-decoration:line-through}.item-note{color:#999;display:block;font-size:22rpx;margin-top:4rpx}