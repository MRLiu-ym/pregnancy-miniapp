.page{padding:24rpx 24rpx 120rpx}.card{background:#fff;border-radius:24rpx;margin-bottom:24rpx;padding:28rpx}.card-title{margin-bottom:20rpx}.card-title text{color:#333;font-size:30rpx;font-weight:700}.no-data{color:#ccc;display:block;font-size:26rpx;padding:40rpx 0;text-align:center}.chart-simple{align-items:flex-end;display:flex;gap:16rpx;height:200rpx;padding-top:20rpx}.bar-wrap{align-items:center;display:flex;flex:1;flex-direction:column;gap:4rpx}.bar{background:linear-gradient(0deg,#f472b6,#f9a8d4);border-radius:8rpx 8rpx 0 0;min-height:20rpx;width:100%}.bar-date{color:#ccc;font-size:18rpx}.bar-val{color:#666;font-size:20rpx}.list-row{border-bottom:1rpx solid #f5f5f5;display:flex;justify-content:space-between;padding:16rpx 0}.list-date{color:#999;font-size:24rpx}.list-val{font-size:26rpx;font-weight:700}.list-val.high{color:#dc2626}.list-val.ok{color:#22c55e}.stats{display:flex;gap:16rpx}.stat-card{background:#fff;border-radius:20rpx;flex:1;padding:24rpx;text-align:center}.stat-label{color:#999;display:block;font-size:22rpx}.stat-num{color:#333;display:block;font-size:40rpx;font-weight:700;margin-top:8rpx}