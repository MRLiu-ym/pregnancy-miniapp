.welcome{align-items:center;display:flex;flex-direction:column;height:100vh;justify-content:center;padding:60rpx;text-align:center}.welcome-emoji{font-size:80rpx;margin-bottom:30rpx}.welcome-title{color:#333;font-size:40rpx;font-weight:700;margin-bottom:16rpx}.welcome-desc{color:#999;font-size:28rpx;line-height:1.6;margin-bottom:40rpx;white-space:pre-line}.btn{background:#f472b6;border-radius:40rpx;color:#fff;font-size:32rpx;font-weight:700;padding:24rpx 60rpx}.page{padding:24rpx 24rpx 120rpx}.card-gradient{background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:32rpx;margin-bottom:24rpx;padding:36rpx}.progress-wrap{align-items:center;display:flex;gap:30rpx}.progress-circle{align-items:center;background:hsla(0,0%,100%,.2);border-radius:50%;display:flex;flex-direction:column;flex-shrink:0;height:140rpx;justify-content:center;width:140rpx}.progress-num{color:#fff;font-size:56rpx;font-weight:700}.progress-total{color:hsla(0,0%,100%,.7);font-size:22rpx}.progress-info{flex:1}.stage{color:hsla(0,0%,100%,.7);font-size:24rpx}.week{color:#fff;font-size:36rpx;font-weight:700;margin:6rpx 0}.due{color:hsla(0,0%,100%,.7);font-size:24rpx}.countdown{background:hsla(0,0%,100%,.2);border-radius:20rpx;display:inline-block;margin-top:12rpx;padding:8rpx 16rpx}.countdown text{color:#fff;font-size:22rpx}.risk-card{border-radius:24rpx;display:flex;gap:16rpx;margin-bottom:16rpx;padding:24rpx}.risk-urgent{background:#fef2f2;border:1rpx solid #fecaca}.risk-high{background:#fffbeb;border:1rpx solid #fde68a}.risk-icon{font-size:32rpx}.risk-body{flex:1}.risk-title{color:#333;display:block;font-size:28rpx;font-weight:700}.risk-desc{color:#666;display:block;font-size:24rpx;margin-top:4rpx}.risk-sugg{color:#333;display:block;font-size:24rpx;font-weight:500;margin-top:6rpx}.card{background:#fff;border-radius:24rpx;margin-bottom:24rpx;padding:28rpx}.card-header{align-items:center;display:flex;gap:16rpx;margin-bottom:16rpx}.baby-emoji{font-size:44rpx}.card-title{color:#333;display:block;font-size:30rpx;font-weight:700}.card-sub{color:#999;display:block;font-size:22rpx}.card-header-row{align-items:center;display:flex;justify-content:space-between;margin-bottom:16rpx}.link{color:#f472b6;font-size:24rpx}.fetal-desc{color:#666;display:block;font-size:26rpx;margin-bottom:16rpx}.milestones{display:flex;flex-wrap:wrap;gap:10rpx}.tag{background:#fce4ec;border-radius:20rpx;color:#db2777;font-size:22rpx;padding:6rpx 16rpx}.grid-3{display:grid;gap:16rpx;grid-template-columns:1fr 1fr 1fr;margin-bottom:24rpx}.quick-btn{align-items:center;background:#fff;border-radius:20rpx;display:flex;flex-direction:column;gap:8rpx;padding:24rpx 16rpx}.quick-icon{font-size:36rpx}.quick-label{color:#666;font-size:22rpx}.reminder-item{border-bottom:1rpx solid #f5f5f5;padding:16rpx 0}.reminder-item:last-child{border-bottom:none}.reminder-item text{color:#333;font-size:26rpx}