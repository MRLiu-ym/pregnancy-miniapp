.page{padding:24rpx 24rpx 120rpx}.scroll{height:100%}.empty{align-items:center;color:#999;display:flex;font-size:28rpx;height:60vh;justify-content:center}.reminder-card{border-radius:24rpx;margin-bottom:16rpx;padding:24rpx}.reminder-card.urgent{background:#fef2f2;border:1rpx solid #fecaca}.reminder-card.high{background:#fffbeb;border:1rpx solid #fde68a}.reminder-card.normal{background:#f0f9ff;border:1rpx solid #bae6fd}.reminder-top{display:flex;justify-content:space-between;margin-bottom:12rpx}.reminder-type{color:#999;font-size:22rpx}.reminder-pri{border-radius:10rpx;font-size:20rpx;padding:2rpx 10rpx}.reminder-pri.urgent{background:#fee2e2;color:#dc2626}.reminder-pri.high{background:#fef3c7;color:#d97706}.reminder-pri.normal{background:#dbeafe;color:#2563eb}.reminder-title{color:#333;display:block;font-size:30rpx;font-weight:700;margin-bottom:8rpx}.reminder-desc{color:#666;display:block;font-size:24rpx;line-height:1.5}.reminder-time{color:#999;display:block;font-size:22rpx;margin-top:10rpx}