.page{background:#f8f8f8;display:flex;flex-direction:column;height:100vh}.cat-scroll{background:#fff;border-bottom:1rpx solid #f0f0f0;padding:16rpx 0;white-space:nowrap}.cat-list{display:inline-flex;gap:12rpx;padding:0 24rpx}.cat-tag{background:#f5f5f5;border-radius:24rpx;color:#666;display:inline-flex;font-size:26rpx;padding:12rpx 20rpx;white-space:nowrap}.cat-tag.active{background:linear-gradient(135deg,#f472b6,#ec4899);color:#fff}.scroll{flex:1;padding:24rpx}.k-item{border-bottom:1rpx solid #f0f0f0}.k-item:last-child{border-bottom:none}.k-question{align-items:center;display:flex;justify-content:space-between;padding:24rpx 0}.k-q-text{color:#333;flex:1;font-size:28rpx;font-weight:500;line-height:1.5}.k-arrow{color:#999;font-size:28rpx;margin-left:12rpx}.k-answer{margin-top:-8rpx;padding:0 0 24rpx}.k-a-text{background:#f9f9f9;border-radius:12rpx;color:#666;display:block;font-size:26rpx;line-height:1.8;padding:20rpx;white-space:pre-wrap}