.page{background:#f8f8f8;min-height:100vh;padding:24rpx 24rpx 120rpx}.tabs{background:#fff;border-radius:16rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);display:flex;margin-bottom:24rpx;padding:6rpx}.tab{border-radius:12rpx;color:#999;flex:1;font-size:26rpx;padding:16rpx;text-align:center;transition:all .2s}.tab.active{background:#fce4ec;color:#db2777;font-weight:700}.card{background:#fff;border-radius:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin-bottom:24rpx;padding:28rpx}.card-title-row{border-bottom:1rpx solid #f5f5f5;margin-bottom:24rpx;padding-bottom:16rpx}.card-title-row text{color:#333;font-size:30rpx;font-weight:700}.row{align-items:center;border-bottom:1rpx solid #f8f8f8;display:flex;justify-content:space-between;padding:20rpx 0}.row:last-child{border-bottom:none}.row-label{color:#999;font-size:26rpx}.row-value{color:#333;font-size:26rpx;font-weight:500}.row-value.hl{color:#db2777;font-weight:700}.field{margin-bottom:24rpx}.field-label{color:#666;display:block;font-size:26rpx;font-weight:500;margin-bottom:12rpx}.input{background:#f5f5f5;border:none;border-radius:16rpx;box-sizing:border-box;color:#333;font-size:28rpx;height:80rpx;line-height:40rpx;padding:20rpx 24rpx;width:100%}.input::-moz-placeholder{color:#ccc}.input::placeholder{color:#ccc}.btn{background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:24rpx;box-shadow:0 4rpx 16rpx rgba(244,114,182,.3);color:#fff;font-size:30rpx;font-weight:700;margin-top:16rpx;padding:24rpx;text-align:center}.btn-cancel{background:#f5f5f5;border-radius:24rpx;color:#666;flex:1;font-size:30rpx;font-weight:500;padding:24rpx;text-align:center}.type-btns{display:flex;gap:12rpx;margin-bottom:20rpx}.type-btn{background:#f5f5f5;border-radius:12rpx;color:#999;flex:1;font-size:24rpx;font-weight:500;padding:16rpx;text-align:center;transition:all .2s}.type-btn.active{background:linear-gradient(135deg,#fce4ec,#fdf2f8);box-shadow:0 2rpx 8rpx rgba(244,114,182,.15);color:#db2777;font-weight:700}.record-row{align-items:center;border-bottom:1rpx solid #f8f8f8;display:flex;justify-content:space-between;padding:18rpx 0}.record-date{color:#999;font-size:24rpx}.record-val{color:#333;font-size:28rpx;font-weight:700}.checkup-item{align-items:flex-start;border-bottom:1rpx solid #f8f8f8;display:flex;gap:16rpx;padding:20rpx 0}.checkup-item:last-child{border-bottom:none}.dot{background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:50%;box-shadow:0 2rpx 6rpx rgba(244,114,182,.3);flex-shrink:0;height:14rpx;margin-top:8rpx;width:14rpx}.checkup-name{color:#333;display:block;font-size:28rpx;font-weight:700}.checkup-info{color:#999;display:block;font-size:24rpx;margin-top:6rpx}.empty{align-items:center;color:#ccc;display:flex;font-size:28rpx;height:60vh;justify-content:center}