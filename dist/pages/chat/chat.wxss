.chat-page{background:#f8f8f8;display:flex;flex-direction:column;height:100vh}.msg-list{flex:1;padding:24rpx 24rpx 16rpx}.msg{display:flex;margin-bottom:24rpx}.msg.user{justify-content:flex-end}.bubble{border-radius:24rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);max-width:80%;padding:20rpx 24rpx}.bubble.user{background:linear-gradient(135deg,#f472b6,#ec4899);border-bottom-right-radius:8rpx}.bubble.user .bubble-text{color:#fff}.bubble.assistant{background:#fff;border-bottom-left-radius:8rpx}.bubble-text{color:#333;font-size:28rpx;line-height:1.6;white-space:pre-wrap}.input-bar{background:#fff;border-top:1rpx solid #f0f0f0;display:flex;gap:12rpx;padding:16rpx 24rpx}.chat-input{background:#f5f5f5;border:none;border-radius:24rpx;flex:1;font-size:28rpx;height:72rpx;padding:16rpx 24rpx}.send-btn{align-items:center;background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:24rpx;color:#fff;display:flex;font-size:28rpx;font-weight:600;justify-content:center;padding:16rpx 28rpx}.quick-btns{background:#fff;display:flex;flex-wrap:wrap;gap:10rpx;padding:0 24rpx 16rpx}.quick{background:#f5f5f5;border-radius:20rpx;color:#666;font-size:24rpx;font-weight:500;padding:10rpx 20rpx}.quick:active{background:#fce4ec;color:#db2777}.loading-bubble{align-items:center;display:flex;gap:12rpx}.dots{display:flex;gap:6rpx}.dot{animation:bounce 1.4s infinite;background:#ccc;border-radius:50%;height:8rpx;width:8rpx}.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}@keyframes bounce{0%,100%,80%{opacity:.4;transform:scale(.6)}40%{opacity:1;transform:scale(1)}}