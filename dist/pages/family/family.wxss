.page{background:#f8f8f8;display:flex;flex-direction:column;height:100vh}.tab-row{background:#fff;border-bottom:1rpx solid #f0f0f0;display:flex;gap:12rpx;padding:12rpx 16rpx}.switch-tab{background:#f5f5f5;border-radius:16rpx;color:#666;flex:1;font-size:26rpx;padding:14rpx;text-align:center}.switch-tab.active{background:linear-gradient(135deg,#f472b6,#ec4899);color:#fff;font-weight:600}.scroll{flex:1;padding:16rpx}.card{background:#fff;border-radius:20rpx;margin-bottom:16rpx;padding:24rpx}.card-header{align-items:center;display:flex;gap:12rpx;margin-bottom:18rpx}.card-icon{font-size:32rpx}.card-title{color:#333;font-size:28rpx;font-weight:700}.item-list{display:flex;flex-direction:column;gap:12rpx}.family-item{align-items:flex-start;display:flex;gap:10rpx}.item-dot{color:#f472b6;flex-shrink:0;font-size:24rpx;font-weight:700}.item-text{color:#555;flex:1;font-size:26rpx;line-height:1.5}.highlight-card{background:linear-gradient(135deg,#fff5f7,#fce4ec);border:1rpx solid #fbcfe8}.highlight-title{color:#db2777;display:block;font-size:26rpx;font-weight:700;margin-bottom:12rpx}.highlight-text{color:#555;display:block;font-size:26rpx;line-height:1.8}