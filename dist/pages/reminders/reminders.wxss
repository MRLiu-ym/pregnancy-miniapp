.page{background:#f8f8f8;min-height:100vh;padding:24rpx 24rpx 120rpx}.scroll{height:100%}.empty{align-items:center;color:#ccc;display:flex;font-size:28rpx;height:60vh;justify-content:center}.reminder-card{border-radius:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);margin-bottom:20rpx;padding:28rpx}.reminder-card.urgent{background:linear-gradient(135deg,#fef2f2,#fff);border:1rpx solid #fecaca}.reminder-card.high{background:linear-gradient(135deg,#fffbeb,#fff);border:1rpx solid #fde68a}.reminder-card.normal{background:linear-gradient(135deg,#f0f9ff,#fff);border:1rpx solid #bae6fd}.reminder-top{align-items:center;display:flex;justify-content:space-between;margin-bottom:16rpx}.reminder-type{color:#999;font-size:24rpx;font-weight:500}.reminder-pri{border-radius:12rpx;font-size:20rpx;font-weight:600;padding:4rpx 14rpx}.reminder-pri.urgent{background:#fee2e2;color:#dc2626}.reminder-pri.high{background:#fef3c7;color:#d97706}.reminder-pri.normal{background:#dbeafe;color:#2563eb}.reminder-title{color:#333;display:block;font-size:30rpx;font-weight:700;margin-bottom:10rpx}.reminder-desc{color:#666;display:block;font-size:26rpx;line-height:1.6}.reminder-time{color:#999;display:block;font-size:22rpx;font-weight:500;margin-top:12rpx}