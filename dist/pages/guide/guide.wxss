.guide-page{background:#f8f8f8;display:flex;flex-direction:column;height:100vh}.guide-header{align-items:center;background:linear-gradient(135deg,#f472b6,#ec4899);display:flex;gap:20rpx;padding:28rpx 28rpx 24rpx}.guide-week-badge{align-items:center;background:hsla(0,0%,100%,.2);border:3rpx solid hsla(0,0%,100%,.3);border-radius:50%;display:flex;flex-direction:column;flex-shrink:0;height:80rpx;justify-content:center;width:80rpx}.guide-week-num{color:#fff;font-size:36rpx;font-weight:700;line-height:1}.guide-week-label{color:hsla(0,0%,100%,.7);font-size:18rpx}.guide-header-info{flex:1}.guide-stage{color:hsla(0,0%,100%,.8);display:block;font-size:22rpx}.guide-summary{color:#fff;display:block;font-size:26rpx;font-weight:600;line-height:1.4;margin-top:4rpx}.tab-scroll{background:#fff;border-bottom:1rpx solid #f0f0f0;white-space:nowrap}.tab-list{display:inline-flex;gap:4rpx;padding:12rpx 16rpx}.guide-tab{background:#f5f5f5;border-radius:20rpx;color:#666;display:inline-flex;font-size:24rpx;padding:10rpx 18rpx;white-space:nowrap}.guide-tab.active{background:#fce4ec;color:#db2777;font-weight:600}.content-scroll{flex:1;padding:16rpx}.content-card{background:#fff;border-radius:20rpx;padding:24rpx}.content-list{display:flex;flex-direction:column;gap:14rpx}.content-item{align-items:flex-start;border-radius:14rpx;display:flex;gap:12rpx;padding:14rpx 16rpx}.content-item.do{background:#f0fdf4}.content-item.dont{background:#fef2f2}.content-item.info{background:#f8fafc}.content-item.baby{background:#fff7ed}.content-item.nutrition-item{background:#f0fdf4}.content-item.husband{background:#eff6ff}.content-item.family{background:#fdf2f8}.content-item.shopping-item{background:#fffbe6}.item-bullet{flex-shrink:0;font-size:24rpx}.item-text{color:#333;flex:1;font-size:26rpx;line-height:1.5}.recipe-list{display:flex;flex-direction:column;gap:14rpx}.recipe-card{background:#fff7ed;border-radius:16rpx;padding:20rpx}.recipe-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:8rpx}.recipe-meal{color:#999;font-size:22rpx}.thyroid-tag{background:#fce4ec;border-radius:10rpx;color:#db2777;font-size:20rpx;padding:4rpx 10rpx}.recipe-name{color:#333;display:block;font-size:28rpx;font-weight:600;margin-bottom:6rpx}.recipe-desc{color:#666;display:block;font-size:24rpx}.thyroid-card{background:#fff5f5;border:1rpx solid #fecaca;border-radius:20rpx;margin-top:16rpx;padding:24rpx}.thyroid-title-row{align-items:center;display:flex;gap:10rpx;margin-bottom:12rpx}.thyroid-icon{font-size:28rpx}.thyroid-title{color:#dc2626;font-size:28rpx;font-weight:700}.thyroid-text{color:#555;font-size:26rpx;line-height:1.7}.empty-page{align-items:center;display:flex;flex-direction:column;height:100vh;justify-content:center;padding:60rpx;text-align:center}.empty-icon{font-size:64rpx;margin-bottom:20rpx}.empty-title{color:#333;font-size:32rpx;font-weight:700;margin-bottom:12rpx}.empty-desc{color:#999;font-size:26rpx;line-height:1.5;margin-bottom:30rpx;white-space:pre-line}.btn{background:linear-gradient(135deg,#f472b6,#ec4899);border-radius:32rpx;color:#fff;display:inline-block;font-size:28rpx;font-weight:700;padding:20rpx 48rpx}